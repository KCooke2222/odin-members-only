<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>New Message</title>
  </head>
  <body>
    <h1>Send Message</h1>

    <form action="/messages/new" method="POST">
      <label for="text">Message</label>
      <textarea id="text" name="text" rows="4" required></textarea>

      <input
        id="image_url"
        name="image_url"
        type="hidden"
        value="https://media.giphy.com/media/12mX8YzVVmomuA/giphy.gif"
      />

      <div>
        <button
          type="button"
          data-image="https://media.giphy.com/media/12mX8YzVVmomuA/giphy.gif"
        >
          Lion
        </button>

        <button
          type="button"
          data-image="https://media.giphy.com/media/QZyBvNVaMbIZ9yadec/giphy.gif"
        >
          Waiting
        </button>

        <button
          type="button"
          data-image="https://media.giphy.com/media/uFEyYkL9pnjy/giphy.gif"
        >
          Flying Dog
        </button>
      </div>

      <img
        id="imagePreview"
        src="https://media.giphy.com/media/12mX8YzVVmomuA/giphy.gif"
        alt="Selected GIF preview"
        width="250"
      />

      <button type="submit">Send</button>
    </form>

    <script>
      const imageInput = document.querySelector("#image");
      const imagePreview = document.querySelector("#imagePreview");
      const imageButtons = document.querySelectorAll("[data-image]");

      imageButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const image = button.dataset.image;
          imageInput.value = image;
          imagePreview.src = image;
        });
      });
    </script>
  </body>
</html>
