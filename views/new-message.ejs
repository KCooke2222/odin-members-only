<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/styles.css" />
    <title>New Message</title>
  </head>
  <body>
    <p><a href="/">Back to board</a></p>
    <h1>Send Message</h1>

    <form action="/messages/new" method="POST">
      <label for="text">Message</label>
      <textarea id="text" name="text" rows="4" required></textarea>

      <fieldset>
        <legend>Image</legend>

        <div class="image-options">
          <input
            class="image-choice"
            id="image-lion"
            name="image_url"
            type="radio"
            value="https://media.giphy.com/media/12mX8YzVVmomuA/giphy.gif"
            checked
          />
          <label class="image-option" for="image-lion">
            <img
              src="https://media.giphy.com/media/12mX8YzVVmomuA/giphy.gif"
              alt=""
            />
          </label>

          <input
            class="image-choice"
            id="image-waiting"
            name="image_url"
            type="radio"
            value="https://media.giphy.com/media/QZyBvNVaMbIZ9yadec/giphy.gif"
          />
          <label class="image-option" for="image-waiting">
            <img
              src="https://media.giphy.com/media/QZyBvNVaMbIZ9yadec/giphy.gif"
              alt=""
            />
          </label>

          <input
            class="image-choice"
            id="image-dog"
            name="image_url"
            type="radio"
            value="https://media.giphy.com/media/uFEyYkL9pnjy/giphy.gif"
          />
          <label class="image-option" for="image-dog">
            <img
              src="https://media.giphy.com/media/uFEyYkL9pnjy/giphy.gif"
              alt=""
            />
          </label>
        </div>
      </fieldset>

      <button type="submit">Send</button>
    </form>
  </body>
</html>
