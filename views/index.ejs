<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Log In</title>
</head>
<body>
  <% if (locals.currentUser) {%>
    <h1>WELCOME BACK <%= currentUser.username %></h1>
    <a href="/messages/new">CREATE NEW MESSAGE</a>
    <a href="/users/become-member">BECOME MEMBER</a>
    <a href="/users/log-out">LOG OUT</a>
  <% } else { %>
    <h1>please log in</h1>
    <form action="/users/log-in" method="POST">
      <label for="username">Username</label>
      <input id="username" name="username" placeholder="username" type="text" />
      <label for="password">Password</label>
      <input id="password" name="password" type="password" />
      <button type="submit">Log In</button>
    </form>
  <%}%>
  <% messages.forEach((message) => { %>
  <article>
    <p><%= message.text %></p>

    <% if (message.image_url) { %>
      <img src="<%= message.image_url %>" alt="" width="200" />
    <% } %>

    <% if (message.username) { %>
      <p>By <%= message.username %></p>
    <% } %>

    <% if (message.created_at) { %>
      <p><%= message.created_at.toLocaleString() %></p>
    <% } %>
  </article>
<% }) %>
</body>
</html>
