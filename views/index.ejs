<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/styles.css">
  <title>Members Only</title>
</head>
<body>
  <header>
    <h1>Members Only</h1>

    <% if (locals.currentUser) {%>
      <p>Welcome back, <%= currentUser.username %>.</p>
      <nav>
        <a href="/messages/new">Create new message</a>
        <a href="/users/become-member">Become member</a>
        <a href="/users/log-out">Log out</a>
      </nav>
    <% } else { %>
      <p>Please log in.</p>
    <% } %>
  </header>

  <main>
    <% if (!locals.currentUser) { %>
    <form action="/users/log-in" method="POST">
      <label for="username">Username</label>
      <input id="username" name="username" placeholder="username" type="text" />
      <label for="password">Password</label>
      <input id="password" name="password" type="password" />
      <button type="submit">Log In</button>
    </form>
    <p><a href="/users/sign-up">Create an account</a></p>
    <%}%>

  <% messages.forEach((message) => { %>
    <article>
      <p><%= message.text %></p>

      <% if (message.image_url) { %>
        <img src="<%= message.image_url %>" alt="" width="200" />
      <% } %>

      <% if (message.username) { %>
        <p class="meta">By <%= message.username %></p>
      <% } %>

      <% if (message.created_at) { %>
        <p class="meta"><%= message.created_at.toLocaleString() %></p>
      <% } %>

      <% if (currentUser && currentUser.membership === "admin") { %>
        <form action="/messages/<%= message.id %>/delete" method="POST">
          <button type="submit">Delete</button>
        </form>
      <% } %>
    </article>
  <% }) %>
  </main>
</body>
</html>
